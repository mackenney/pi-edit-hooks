{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true
  },
  "include": [
    "index.ts",
    "types.ts",
    "glob.ts",
    "substitute.ts",
    "discover.ts",
    "resolve.ts",
    "core.ts"
  ],
  "exclude": [
    "node_modules",
    "test-repos"
  ]
}
